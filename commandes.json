[
  {
    "id": "dir-get-childitem",
    "category": "Fichiers & Dossiers",
    "level": "Basique",
    "usage": "Navigation",
    "equivalence": "Partielle",
    "action": "Lister les fichiers et dossiers",
    "cmd": "dir C:\\",
    "powershell": "Get-ChildItem -Path C:\\",
    "alias": ["ls", "dir", "gci"],
    "description": "Affiche le contenu d'un dossier. PowerShell retourne des objets, pas seulement du texte.",
    "note": "Get-ChildItem peut etre combine avec Where-Object, Sort-Object ou Select-Object.",
    "example": "Get-ChildItem -Path C:\\Windows -Recurse",
    "fields": [
      { "name": "path", "label": "Chemin", "placeholder": "C:\\Temp", "default": "C:\\Temp" }
    ],
    "cmdTemplate": "dir {{path}}",
    "psTemplate": "Get-ChildItem -Path {{path}}"
  },
  {
    "id": "cd-set-location",
    "category": "Fichiers & Dossiers",
    "level": "Basique",
    "usage": "Navigation",
    "equivalence": "Parfaite",
    "action": "Changer de dossier",
    "cmd": "cd C:\\Temp",
    "powershell": "Set-Location -Path C:\\Temp",
    "alias": ["cd", "sl"],
    "description": "Change le repertoire courant de la session.",
    "note": "Les alias cd et sl pointent vers Set-Location dans PowerShell.",
    "example": "Set-Location -Path $HOME\\Documents",
    "fields": [
      { "name": "path", "label": "Chemin", "placeholder": "C:\\Temp", "default": "C:\\Temp" }
    ],
    "cmdTemplate": "cd {{path}}",
    "psTemplate": "Set-Location -Path {{path}}"
  },
  {
    "id": "mkdir-new-item",
    "category": "Fichiers & Dossiers",
    "level": "Basique",
    "usage": "Creation",
    "equivalence": "Parfaite",
    "action": "Creer un dossier",
    "cmd": "mkdir Logs",
    "powershell": "New-Item -ItemType Directory -Path Logs",
    "alias": ["mkdir", "ni"],
    "description": "Cree un nouveau repertoire.",
    "note": "New-Item sert aussi a creer des fichiers, cles de registre et autres fournisseurs PowerShell.",
    "example": "New-Item -ItemType Directory -Path C:\\Temp\\Logs",
    "fields": [
      { "name": "path", "label": "Dossier", "placeholder": "Logs", "default": "Logs" }
    ],
    "cmdTemplate": "mkdir {{path}}",
    "psTemplate": "New-Item -ItemType Directory -Path {{path}}"
  },
  {
    "id": "del-remove-item",
    "category": "Fichiers & Dossiers",
    "level": "Basique",
    "usage": "Suppression",
    "equivalence": "Partielle",
    "action": "Supprimer un fichier ou dossier",
    "cmd": "del fichier.txt",
    "powershell": "Remove-Item -Path fichier.txt",
    "alias": ["rm", "del", "erase", "ri"],
    "description": "Supprime un element. PowerShell demande plus souvent d'expliciter -Recurse pour les dossiers.",
    "note": "Attention aux scripts : Remove-Item -Recurse -Force peut supprimer beaucoup de donnees.",
    "example": "Remove-Item -Path .\\old -Recurse -Force",
    "fields": [
      { "name": "path", "label": "Element", "placeholder": "fichier.txt", "default": "fichier.txt" }
    ],
    "cmdTemplate": "del {{path}}",
    "psTemplate": "Remove-Item -Path {{path}}"
  },
  {
    "id": "copy-copy-item",
    "category": "Fichiers & Dossiers",
    "level": "Basique",
    "usage": "Copie",
    "equivalence": "Partielle",
    "action": "Copier un element",
    "cmd": "copy source.txt cible.txt",
    "powershell": "Copy-Item -Path source.txt -Destination cible.txt",
    "alias": ["copy", "cp", "cpi"],
    "description": "Copie un fichier ou un dossier vers une destination.",
    "note": "Pour copier un dossier complet avec PowerShell, ajoute souvent -Recurse.",
    "example": "Copy-Item -Path .\\rapport.docx -Destination D:\\Sauvegarde\\",
    "fields": [
      { "name": "source", "label": "Source", "placeholder": "source.txt", "default": "source.txt" },
      { "name": "destination", "label": "Destination", "placeholder": "cible.txt", "default": "cible.txt" }
    ],
    "cmdTemplate": "copy {{source}} {{destination}}",
    "psTemplate": "Copy-Item -Path {{source}} -Destination {{destination}}"
  },
  {
    "id": "move-move-item",
    "category": "Fichiers & Dossiers",
    "level": "Basique",
    "usage": "Deplacement",
    "equivalence": "Partielle",
    "action": "Deplacer ou renommer un element",
    "cmd": "move ancien.txt nouveau.txt",
    "powershell": "Move-Item -Path ancien.txt -Destination nouveau.txt",
    "alias": ["move", "mv", "mi"],
    "description": "Deplace ou renomme un fichier ou dossier.",
    "note": "Move-Item accepte aussi des chemins de fournisseurs PowerShell comme Cert: ou Registry.",
    "example": "Move-Item -Path .\\logs -Destination C:\\Archive\\logs",
    "fields": [
      { "name": "source", "label": "Source", "placeholder": "ancien.txt", "default": "ancien.txt" },
      { "name": "destination", "label": "Destination", "placeholder": "nouveau.txt", "default": "nouveau.txt" }
    ],
    "cmdTemplate": "move {{source}} {{destination}}",
    "psTemplate": "Move-Item -Path {{source}} -Destination {{destination}}"
  },
  {
    "id": "ping-test-connection",
    "category": "Reseau",
    "level": "Basique",
    "usage": "Diagnostic",
    "equivalence": "Partielle",
    "action": "Tester la connectivite reseau",
    "cmd": "ping 8.8.8.8",
    "powershell": "Test-Connection -TargetName 8.8.8.8",
    "alias": ["ping"],
    "description": "Envoie des requetes ICMP pour verifier si une machine repond.",
    "note": "Selon la version PowerShell, le nombre de requetes et les options different de ping.exe.",
    "example": "Test-Connection -TargetName google.com -Count 4",
    "fields": [
      { "name": "target", "label": "IP ou DNS", "placeholder": "8.8.8.8", "default": "8.8.8.8" }
    ],
    "cmdTemplate": "ping {{target}}",
    "psTemplate": "Test-Connection -TargetName {{target}}"
  },
  {
    "id": "ipconfig-get-netipaddress",
    "category": "Reseau",
    "level": "Avance",
    "usage": "Diagnostic",
    "equivalence": "Partielle",
    "action": "Afficher la configuration IP",
    "cmd": "ipconfig /all",
    "powershell": "Get-NetIPAddress -AddressFamily IPv4",
    "alias": ["gip"],
    "description": "Liste les adresses IP et interfaces reseau. PowerShell expose des objets filtrables.",
    "note": "Get-NetIPConfiguration est souvent plus proche de ipconfig /all pour une vue globale.",
    "example": "Get-NetIPAddress -AddressFamily IPv4 | Select-Object InterfaceAlias,IPAddress",
    "fields": [],
    "cmdTemplate": "ipconfig /all",
    "psTemplate": "Get-NetIPAddress -AddressFamily IPv4"
  },
  {
    "id": "nslookup-resolve-dnsname",
    "category": "Reseau",
    "level": "Avance",
    "usage": "DNS",
    "equivalence": "Partielle",
    "action": "Resoudre un nom DNS",
    "cmd": "nslookup openai.com",
    "powershell": "Resolve-DnsName -Name openai.com",
    "alias": [],
    "description": "Interroge le DNS pour obtenir les enregistrements d'un domaine.",
    "note": "Resolve-DnsName retourne des objets par type d'enregistrement.",
    "example": "Resolve-DnsName -Name microsoft.com -Type MX",
    "fields": [
      { "name": "name", "label": "Nom DNS", "placeholder": "openai.com", "default": "openai.com" }
    ],
    "cmdTemplate": "nslookup {{name}}",
    "psTemplate": "Resolve-DnsName -Name {{name}}"
  },
  {
    "id": "netstat-get-nettcpconnection",
    "category": "Reseau",
    "level": "Avance",
    "usage": "Diagnostic",
    "equivalence": "Partielle",
    "action": "Voir les connexions TCP",
    "cmd": "netstat -ano",
    "powershell": "Get-NetTCPConnection",
    "alias": [],
    "description": "Affiche les connexions TCP, ports locaux et etats.",
    "note": "Get-NetTCPConnection est plus simple a filtrer par etat, port ou processus.",
    "example": "Get-NetTCPConnection -State Listen",
    "fields": [],
    "cmdTemplate": "netstat -ano",
    "psTemplate": "Get-NetTCPConnection"
  },
  {
    "id": "tracert-test-netconnection",
    "category": "Reseau",
    "level": "Avance",
    "usage": "Diagnostic",
    "equivalence": "Partielle",
    "action": "Tracer ou tester un chemin reseau",
    "cmd": "tracert 1.1.1.1",
    "powershell": "Test-NetConnection -ComputerName 1.1.1.1 -TraceRoute",
    "alias": ["tnc"],
    "description": "Teste une destination et peut afficher la route empruntee.",
    "note": "Test-NetConnection sait aussi tester un port TCP avec -Port.",
    "example": "Test-NetConnection -ComputerName serveur.local -Port 443",
    "fields": [
      { "name": "target", "label": "Cible", "placeholder": "1.1.1.1", "default": "1.1.1.1" }
    ],
    "cmdTemplate": "tracert {{target}}",
    "psTemplate": "Test-NetConnection -ComputerName {{target}} -TraceRoute"
  },
  {
