  {
    "id": "taskkill-stop-process",
    "category": "Systeme / Processus",
    "level": "Basique",
    "usage": "Processus",
    "equivalence": "Partielle",
    "action": "Arreter un processus",
    "cmd": "taskkill /PID 1234 /F",
    "powershell": "Stop-Process -Id 1234 -Force",
    "alias": ["kill", "spps"],
    "description": "Termine un processus par PID ou par nom.",
    "note": "Stop-Process peut etre combine avec Get-Process dans un pipeline.",
