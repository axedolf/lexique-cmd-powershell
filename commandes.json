  {
    "id": "tracert-test-netconnection",
    "category": "Reseau",
    "level": "Avance",
    "usage": "Diagnostic",
    "equivalence": "Partielle",
    "action": "Suivre la route des paquets (Traceroute)",
    "cmd": "tracert <cible>",
    "powershell": "Test-NetConnection -ComputerName <cible> -TraceRoute",
    "alias": ["tracert", "tnc"],
    "description": "Determine le chemin pris par les paquets pour atteindre une destination et identifie les routeurs lents ou defaillants.",
    "note": "Test-NetConnection -TraceRoute donne une vue PowerShell du traceroute. L'alias tracert lance generalement tracert.exe.",
    "example": "CMD: tracert google.fr | PS: Test-NetConnection -ComputerName google.fr -TraceRoute",
    "exampleCmd": "tracert google.fr",
    "examplePs": "Test-NetConnection -ComputerName google.fr -TraceRoute",
    "fields": [
      { "name": "target", "label": "Cible", "placeholder": "google.fr", "default": "google.fr" }
    ],
    "cmdTemplate": "tracert {{target}}",
    "psTemplate": "Test-NetConnection -ComputerName {{target}} -TraceRoute"
  },
  {
    "id": "test-port-tcp",
    "category": "Reseau",
    "level": "Avance",
    "usage": "Diagnostic",
    "equivalence": "Partielle",
    "action": "Tester un port TCP",
    "cmd": "telnet serveur.local 443",
    "powershell": "Test-NetConnection -ComputerName serveur.local -Port 443",
    "alias": ["tnc"],
    "description": "Verifie si un port TCP repond sur une machine distante.",
    "note": "Telnet n'est pas toujours installe. Test-NetConnection est la methode PowerShell la plus pratique.",
    "example": "Test-NetConnection -ComputerName serveur.local -Port 443",
    "fields": [
      { "name": "target", "label": "Cible", "placeholder": "serveur.local", "default": "serveur.local" },
      { "name": "port", "label": "Port", "placeholder": "443", "default": "443" }
    ],
    "cmdTemplate": "telnet {{target}} {{port}}",
    "psTemplate": "Test-NetConnection -ComputerName {{target}} -Port {{port}}"
  },
