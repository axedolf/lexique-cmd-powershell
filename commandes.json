[
  {
    "id": "dir-get-childitem",
    "category": "Fichiers & Dossiers",
    "level": "Basique",
    "usage": "Navigation",
    "equivalence": "Partielle",
    "action": "Lister les fichiers et dossiers",
    "cmd": "dir C:\\",
    "powershell": "Get-ChildItem -Path C:\\",
    "alias": ["ls", "dir", "gci"],
    "description": "Affiche le contenu d'un dossier. PowerShell retourne des objets, pas seulement du texte.",
    "note": "Get-ChildItem peut etre combine avec Where-Object, Sort-Object ou Select-Object.",
    "example": "Get-ChildItem -Path C:\\Windows -Recurse",
    "fields": [
      { "name": "path", "label": "Chemin", "placeholder": "C:\\Temp", "default": "C:\\Temp" }
    ],
    "cmdTemplate": "dir {{path}}",
    "psTemplate": "Get-ChildItem -Path {{path}}"
  },
  {
