  {
    "id": "del-remove-item",
    "category": "Fichiers & Dossiers",
    "level": "Basique",
    "usage": "Suppression",
    "equivalence": "Partielle",
    "action": "Supprimer un fichier ou dossier",
    "cmd": "del fichier.txt",
    "powershell": "Remove-Item -Path fichier.txt",
    "alias": ["rm", "del", "erase", "ri"],
    "description": "Supprime un element. PowerShell demande plus souvent d'expliciter -Recurse pour les dossiers.",
    "note": "Attention aux scripts : Remove-Item -Recurse -Force peut supprimer beaucoup de donnees.",
    "example": "Remove-Item -Path .\\old -Recurse -Force",
