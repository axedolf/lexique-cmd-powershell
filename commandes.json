      { "name": "path", "label": "Element", "placeholder": "fichier.txt", "default": "fichier.txt" }
    ],
    "cmdTemplate": "del {{path}}",
    "psTemplate": "Remove-Item -Path {{path}}"
  },
  {
    "id": "copy-copy-item",
    "category": "Fichiers & Dossiers",
    "level": "Basique",
    "usage": "Copie",
    "equivalence": "Partielle",
    "action": "Copier un element",
    "cmd": "copy source.txt cible.txt",
    "powershell": "Copy-Item -Path source.txt -Destination cible.txt",
    "alias": ["copy", "cp", "cpi"],
    "description": "Copie un fichier ou un dossier vers une destination.",
    "note": "Pour copier un dossier complet avec PowerShell, ajoute souvent -Recurse.",
    "example": "Copy-Item -Path .\\rapport.docx -Destination D:\\Sauvegarde\\",
    "fields": [
      { "name": "source", "label": "Source", "placeholder": "source.txt", "default": "source.txt" },
      { "name": "destination", "label": "Destination", "placeholder": "cible.txt", "default": "cible.txt" }
    ],
    "cmdTemplate": "copy {{source}} {{destination}}",
    "psTemplate": "Copy-Item -Path {{source}} -Destination {{destination}}"
  },
  {
    "id": "move-move-item",
    "category": "Fichiers & Dossiers",
    "level": "Basique",
    "usage": "Deplacement",
    "equivalence": "Partielle",
    "action": "Deplacer ou renommer un element",
    "cmd": "move ancien.txt nouveau.txt",
    "powershell": "Move-Item -Path ancien.txt -Destination nouveau.txt",
    "alias": ["move", "mv", "mi"],
    "description": "Deplace ou renomme un fichier ou dossier.",
